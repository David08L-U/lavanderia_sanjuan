{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama/qwen-vscode:latest",
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "bash": "ask"
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama local",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen-vscode:latest": {
          "name": "Qwen VS Code local"
        }
      }
    }
  }
}
